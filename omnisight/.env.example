APP_NAME=OmniSight
APP_ENV=dev
DEBUG=true

# LLM provider switch
LLM_PROVIDER=ollama

# Common active model field
LLM_MODEL=gemma3:12b


# Ollama OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# OpenAI settings
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-5.4-mini

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=omnisight_products

# Paths
DATA_DIR=./data